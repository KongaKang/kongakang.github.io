          if (playerInput == "1") {
            cout << answersKenny[currentQuestion][0] << endl;
            questionRepeat = false;
            questionCount += 1;
          }
          else if (playerInput == "2") {
            cout << answersKenny[currentQuestion][1] << endl;
            questionRepeat = false;
            questionCount += 1;
          }
          else if (playerInput == "3") {
            cout << answersKenny[currentQuestion][2] << endl;
            questionRepeat = false;
            questionCount += 1;
          }
          else {
            cout << "Please enter either 1, 2 or 3." << endl;
          }
        }

          //Give the player the option to choose which path to take
          cout << "\nNow, choose which sentinel has told the truth (1 or 2)." << endl;
          bool pathRepeat = true;
          while (pathRepeat == true) {
            cin >> playerInput;

            if (playerInput == "1") {
              playerScore += 1;
              cout << "You have chosen correctly. Your current score is: " << playerScore << endl;
              pathRepeat = false;
            }
            else if (playerInput == "2") {
              cout << "You have chosen incorrectly. Your current score is: " << playerScore << endl;
              pathRepeat = false;
            }
            else {
              cout << "Please enter either 1 or 2." << endl;
            }
          }
        }

        // Ask the player for an input to continue the path
        if (playerScore < 6 && questionCount < 6) {
          string continueInput = "q";
          cout << "\nEnter \" c \" to continue the path ";
          while (continueInput != "c") {
            cin >> continueInput;
            if (continueInput != "c") {
              cout << "\nPlease enter \" c \" to continue the path ";
            }
          }
        }
      }

      // Give player final score
      cout << "\n=============================================\n";
      if (playerScore >= 6) {
        cout << "ACCESS GRANTED!\n";
        cout << "You have retrieved the confidential files!\n";
      }   else {
        cout << "ACCESS DENIED.\n";
        cout << "You did not answer enough questions correctly.\n";
      }
      cout << "Final score: " << playerScore << " correct out of " << questionCount << " questions.\n";
      cout << "=============================================\n";

    return 0;
}
